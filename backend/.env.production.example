# ── M-AIDA backend — PRODUCTION environment ────────────────────────────────
# Copy to backend/.env on the server and fill in real values.
# NEVER commit the real .env (it is git-ignored).

# LLM provider (vendor-neutral adapter). Required only for live PDF extraction;
# without a key the /api/extract endpoint returns an explicit 503 and every
# other feature (verify, lock, export, forest data) keeps working.
LLM_PROVIDER=anthropic
LLM_API_KEY=                 # <-- your provider key (SECRET — set as host secret)
LLM_MODEL=                   # <-- your approved model id

# Optional Notion sync (leave blank to disable)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Server
MAIDA_PORT=8765

# CORS — only needed when the frontend is served from a DIFFERENT origin than
# the backend. In the recommended single-host setup the frontend's nginx
# proxies /api/ to the backend (same origin) so this can stay unset.
# CORS_ORIGINS=https://your-domain.example,https://www.your-domain.example
